{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "cd backend && npm run start:sqlite",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "environments": {
    "production": {
      "variables": {
        "NODE_ENV": "production",
        "DATABASE_PATH": "/app/data/dining.db",
        "BACKUP_ENABLED": "true",
        "JWT_SECRET": "${{JWT_SECRET}}"
      }
    }
  }
}